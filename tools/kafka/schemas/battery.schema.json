{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "telemetry.battery",
  "type": "object",
  "required": ["metadata", "data"],
  "additionalProperties": false,

  "properties": {
    "metadata": {
      "type": "object",
      "required": ["row_hash", "vehicle_id", "module", "source_file"],
      "additionalProperties": false,
      "properties": {
        "row_hash": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "module": {
          "type": "string",
          "enum": ["battery"]
        },
        "source_file": { "type": "string" },
        "ingest_ts": {
          "type": "string",
          "format": "date-time",
          "nullable": true
        }
      }
    },

    "data": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
